generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model divisi {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  nama        String
  keterangan  String?
  status      String       @default("Aktif")
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  departments department[]
  karyawan    karyawan[]
}

model department {
  id             Int              @id @default(autoincrement())
  divisi_id      Int
  code           String           @unique
  nama           String
  keterangan     String?
  status         String           @default("Aktif")
  manager_id     Int?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  divisi         divisi           @relation(fields: [divisi_id], references: [id])
  manager        karyawan?        @relation("DepartmentManager", fields: [manager_id], references: [id])
  karyawan       karyawan[]       @relation("KaryawanDepartment")
  posisi_jabatan posisi_jabatan[]
}

model posisi_jabatan {
  id            Int        @id @default(autoincrement())
  department_id Int
  code          String     @unique
  nama          String
  keterangan    String?
  status        String     @default("Aktif")
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  karyawan      karyawan[]
  department    department @relation(fields: [department_id], references: [id])
}

model kategori_pangkat {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  nama        String
  keterangan  String?
  status      String        @default("Aktif")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  karyawan_hr karyawan_hr[]
}

model golongan {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  nama        String
  keterangan  String?
  status      String        @default("Aktif")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  karyawan_hr karyawan_hr[]
}

model sub_golongan {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  nama        String
  keterangan  String?
  status      String        @default("Aktif")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  karyawan_hr karyawan_hr[]
}

model jenis_hubungan_kerja {
  id          Int           @id @default(autoincrement())
  code        String        @unique
  nama        String
  keterangan  String?
  status      String        @default("Aktif")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  karyawan_hr karyawan_hr[]
}

model tag {
  id         Int            @id @default(autoincrement())
  code       String         @unique
  nama       String
  warna      String
  keterangan String?
  status     String         @default("Aktif")
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  karyawan   karyawan_tag[]
}

model lokasi_kerja {
  id                  Int           @id @default(autoincrement())
  code                String        @unique
  nama                String
  alamat              String?
  keterangan          String?
  status              String        @default("Aktif")
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  karyawan            karyawan[]
  karyawan_hr_sebelum karyawan_hr[] @relation("LokasiSebelumnya")
  mess                mess[]
}

model status_karyawan {
  id         Int        @id @default(autoincrement())
  code       String     @unique
  nama       String
  keterangan String?
  status     String     @default("Aktif")
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  karyawan   karyawan[]
}

model karyawan {
  id                   Int                  @id @default(autoincrement())
  foto_karyawan        String?
  nama_lengkap         String
  nomor_induk_karyawan String               @unique
  divisi_id            Int?
  department_id        Int?
  manager_id           Int?
  atasan_langsung_id   Int?
  posisi_jabatan_id    Int?
  email_perusahaan     String?
  nomor_handphone      String?
  status_karyawan_id   Int?
  lokasi_kerja_id      Int?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  mess_room_id         Int?
  status_proses        String               @default("Aktif")
  managed_departments  department[]         @relation("DepartmentManager")
  atasan_langsung      karyawan?            @relation("KaryawanAtasan", fields: [atasan_langsung_id], references: [id])
  bawahan              karyawan[]           @relation("KaryawanAtasan")
  department           department?          @relation("KaryawanDepartment", fields: [department_id], references: [id])
  divisi               divisi?              @relation(fields: [divisi_id], references: [id])
  lokasi_kerja         lokasi_kerja?        @relation(fields: [lokasi_kerja_id], references: [id])
  manager              karyawan?            @relation("KaryawanManager", fields: [manager_id], references: [id])
  managed_by           karyawan[]           @relation("KaryawanManager")
  mess_room            mess_room?           @relation(fields: [mess_room_id], references: [id])
  posisi_jabatan       posisi_jabatan?      @relation(fields: [posisi_jabatan_id], references: [id])
  status_karyawan      status_karyawan?     @relation(fields: [status_karyawan_id], references: [id])
  anak                 karyawan_anak[]
  checklists           karyawan_checklist[]
  dokumen              karyawan_dokumen[]
  hr                   karyawan_hr?
  keluarga             karyawan_keluarga?
  personal             karyawan_personal?
  saudara              karyawan_saudara[]
  tags                 karyawan_tag[]
  users                users[]
  mess_assignments     mess_assignment[]
  mess_petugas         mess_petugas[]
}

model karyawan_tag {
  karyawan_id Int
  tag_id      Int
  karyawan    karyawan @relation(fields: [karyawan_id], references: [id])
  tag         tag      @relation(fields: [tag_id], references: [id])

  @@id([karyawan_id, tag_id])
}

model karyawan_personal {
  id                     Int       @id @default(autoincrement())
  karyawan_id            Int       @unique
  jenis_kelamin          String?
  tempat_lahir           String?
  tanggal_lahir          DateTime?
  email_pribadi          String?
  agama                  String?
  golongan_darah         String?
  nomor_kartu_keluarga   String?
  nomor_ktp              String?
  nomor_npwp             String?
  nomor_bpjs             String?
  no_nik_kk              String?
  status_pajak           String?
  alamat_domisili        String?
  kota_domisili          String?
  provinsi_domisili      String?
  alamat_ktp             String?
  kota_ktp               String?
  provinsi_ktp           String?
  nomor_handphone_2      String?
  nomor_telepon_rumah_1  String?
  nomor_telepon_rumah_2  String?
  status_pernikahan      String?
  nama_pasangan          String?
  tanggal_menikah        DateTime?
  tanggal_cerai          DateTime?
  tanggal_wafat_pasangan DateTime?
  pekerjaan_pasangan     String?
  jumlah_anak            Int?
  nomor_rekening         String?
  nama_pemegang_rekening String?
  nama_bank              String?
  cabang_bank            String?
  nama_ayah              String?
  nama_ibu               String?
  nama_panggilan         String?
  nomor_handphone_1      String?
  karyawan               karyawan  @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
}

model karyawan_hr {
  id                      Int                   @id @default(autoincrement())
  karyawan_id             Int                   @unique
  jenis_hubungan_kerja_id Int?
  tanggal_masuk_group     DateTime?
  tanggal_masuk           DateTime?
  tanggal_permanent       DateTime?
  tanggal_kontrak         DateTime?
  tanggal_akhir_kontrak   DateTime?
  tanggal_berhenti        DateTime?
  tingkat_pendidikan      String?
  bidang_studi            String?
  nama_sekolah            String?
  kota_sekolah            String?
  status_kelulusan        String?
  keterangan_pendidikan   String?
  kategori_pangkat_id     Int?
  golongan_id             Int?
  sub_golongan_id         Int?
  no_dana_pensiun         String?
  emergency_nama_1        String?
  emergency_nomor_1       String?
  emergency_hubungan_1    String?
  emergency_alamat_1      String?
  emergency_nama_2        String?
  emergency_nomor_2       String?
  emergency_hubungan_2    String?
  emergency_alamat_2      String?
  point_of_original       String?
  point_of_hire           String?
  ukuran_seragam_kerja    String?
  ukuran_sepatu_kerja     String?
  lokasi_sebelumnya_id    Int?
  tanggal_mutasi          DateTime?
  siklus_pembayaran_gaji  String?
  costing                 String?
  assign                  String?
  actual                  String?
  golongan                golongan?             @relation(fields: [golongan_id], references: [id])
  jenis_hubungan_kerja    jenis_hubungan_kerja? @relation(fields: [jenis_hubungan_kerja_id], references: [id])
  karyawan                karyawan              @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
  kategori_pangkat        kategori_pangkat?     @relation(fields: [kategori_pangkat_id], references: [id])
  lokasi_sebelumnya       lokasi_kerja?         @relation("LokasiSebelumnya", fields: [lokasi_sebelumnya_id], references: [id])
  sub_golongan            sub_golongan?         @relation(fields: [sub_golongan_id], references: [id])
}

model karyawan_keluarga {
  id                              Int       @id @default(autoincrement())
  karyawan_id                     Int       @unique
  tanggal_lahir_pasangan          DateTime?
  pendidikan_terakhir_pasangan    String?
  pekerjaan_pasangan              String?
  keterangan_pasangan             String?
  anak_ke                         Int?
  jumlah_saudara_kandung          Int?
  nama_ayah_mertua                String?
  tanggal_lahir_ayah_mertua       DateTime?
  pendidikan_terakhir_ayah_mertua String?
  keterangan_ayah_mertua          String?
  nama_ibu_mertua                 String?
  tanggal_lahir_ibu_mertua        DateTime?
  pendidikan_terakhir_ibu_mertua  String?
  keterangan_ibu_mertua           String?
  pekerjaan_ayah_mertua           String?
  pekerjaan_ibu_mertua            String?
  karyawan                        karyawan  @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
}

model karyawan_anak {
  id            Int       @id @default(autoincrement())
  karyawan_id   Int
  urutan        Int
  nama_anak     String?
  jenis_kelamin String?
  tanggal_lahir DateTime?
  keterangan    String?
  karyawan      karyawan  @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
}

model karyawan_saudara {
  id                  Int       @id @default(autoincrement())
  karyawan_id         Int
  urutan              Int
  nama_saudara        String?
  jenis_kelamin       String?
  tanggal_lahir       DateTime?
  pendidikan_terakhir String?
  pekerjaan           String?
  keterangan          String?
  karyawan            karyawan  @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
}

model users {
  id          Int       @id @default(autoincrement())
  karyawan_id Int?
  nama        String
  nik         String    @unique
  password    String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  karyawan    karyawan? @relation(fields: [karyawan_id], references: [id])
  roles       user_roles[]
}

model roles {
  id          Int                @id @default(autoincrement())
  nama        String             @unique
  deskripsi   String?
  status      String             @default("Aktif")
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  users       user_roles[]
  permissions role_permissions[]
}

model permissions {
  id                Int                @id @default(autoincrement())
  group_id          Int?
  module            String             // e.g., "HR", "Inventory", "Mess", "Building"
  feature           String?            // e.g., "Karyawan", "Room"
  action            String             // e.g., "Create", "Read", "Update", "Delete", "Export", "Import", "Approve"
  field             String?            // Granular field control
  deskripsi         String?
  status            String             @default("Aktif")
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  group             permission_group?  @relation(fields: [group_id], references: [id])
  roles             role_permissions[]
  
  @@unique([module, feature, action, field])
}

model permission_group {
  id          Int           @id @default(autoincrement())
  nama        String        @unique
  deskripsi   String?
  permissions permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model user_roles {
  user_id Int
  role_id Int
  user    users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role    roles @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
}

model security_audit_log {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  action      String   // e.g., "LOGIN", "ROLE_CHANGE", "ACCESS_DENIED"
  resource    String?  // e.g., "Role:Admin"
  details     Json?    // Store change details or audit info
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())
}

model mess {
  id              Int            @id @default(autoincrement())
  code            String         @unique
  nama            String
  lokasi_kerja_id Int?
  blok            String?
  lantai          String?
  keterangan      String?
  status          String         @default("Aktif")
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  lokasi_kerja    lokasi_kerja?  @relation(fields: [lokasi_kerja_id], references: [id])
  rooms           mess_room[]
  petugas         mess_petugas[]
}

model mess_room {
  id                 Int                      @id @default(autoincrement())
  mess_id            Int
  nomor_kamar        String
  kapasitas          Int                      @default(1)
  tipe               String? // Single, Double, VIP
  status             String                   @default("Tersedia") // Tersedia, Penuh, Rusak, Dibersihkan
  created_at         DateTime                 @default(now())
  updated_at         DateTime                 @updatedAt
  mess               mess                     @relation(fields: [mess_id], references: [id], onDelete: Cascade)
  assignments        mess_assignment[]
  facilities         mess_facility_on_room[]
  damage_reports     mess_damage_report[]
  cleaning_schedules mess_cleaning_schedule[]
  penghuni           karyawan[]
}

model mess_facility {
  id         Int                     @id @default(autoincrement())
  nama       String                  @unique
  keterangan String?
  rooms      mess_facility_on_room[]
}

model mess_facility_on_room {
  room_id     Int
  facility_id Int
  room        mess_room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
  facility    mess_facility @relation(fields: [facility_id], references: [id], onDelete: Cascade)

  @@id([room_id, facility_id])
}

model mess_petugas {
  id          Int      @id @default(autoincrement())
  mess_id     Int
  karyawan_id Int
  shift       String?
  mess        mess     @relation(fields: [mess_id], references: [id], onDelete: Cascade)
  karyawan    karyawan @relation(fields: [karyawan_id], references: [id])
}

model mess_assignment {
  id             Int       @id @default(autoincrement())
  room_id        Int
  karyawan_id    Int
  tanggal_masuk  DateTime  @default(now())
  tanggal_keluar DateTime?
  status         String    @default("Aktif") // Aktif, Selesai, Booking
  keterangan     String?
  room           mess_room @relation(fields: [room_id], references: [id], onDelete: Cascade)
  karyawan       karyawan  @relation(fields: [karyawan_id], references: [id])
}

model mess_damage_report {
  id              Int       @id @default(autoincrement())
  room_id         Int
  kategori        String? // AC, Lampu, Plumbing
  deskripsi       String
  foto_kerusakan  String?
  status          String    @default("Dilaporkan") // Dilaporkan, Proses, Selesai
  tanggal_laporan DateTime  @default(now())
  tanggal_selesai DateTime?
  room            mess_room @relation(fields: [room_id], references: [id], onDelete: Cascade)
}

model mess_cleaning_schedule {
  id             Int       @id @default(autoincrement())
  room_id        Int
  tanggal_jadwal DateTime
  status         String    @default("Terjadwal") // Terjadwal, Selesai
  catatan        String?
  room           mess_room @relation(fields: [room_id], references: [id], onDelete: Cascade)
}

model karyawan_dokumen {
  id           Int      @id @default(autoincrement())
  karyawan_id  Int
  nama_dokumen String
  file_path    String
  file_type    String?
  file_size    Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  karyawan     karyawan @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
}

model checklist_template {
  id         Int                  @id @default(autoincrement())
  kategori   String
  tugas      String
  deskripsi  String?
  urutan     Int                  @default(0)
  is_wajib   Boolean              @default(true)
  created_at DateTime             @default(now())
  updated_at DateTime             @updatedAt
  checklists karyawan_checklist[]
}

model karyawan_checklist {
  id                Int                @id @default(autoincrement())
  karyawan_id       Int
  template_id       Int
  is_selesai        Boolean            @default(false)
  tanggal_selesai   DateTime?
  catatan           String?
  user_pemeriksa_id Int?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  karyawan          karyawan           @relation(fields: [karyawan_id], references: [id], onDelete: Cascade)
  template          checklist_template @relation(fields: [template_id], references: [id])
}
